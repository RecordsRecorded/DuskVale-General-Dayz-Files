FrameWidgetClass rootFrame {
 size 1 1
 halign center_ref
 valign center_ref
 hexactpos 1
 vexactpos 1
 hexactsize 0
 vexactsize 0
 scriptclass ""
 {
  MapWidgetClass mapWidget {
   size 1 1
   halign center_ref
   hexactpos 1
   vexactpos 1
   hexactsize 0
   vexactsize 0
   scriptclass "LBGapHandler"
   {
    ScriptParamsClass {
     gapVertical 40
    }
   }
  }
  TextWidgetClass txt_info {
   ignorepointer 1
   position 3 0
   size 1 20
   halign center_ref
   valign bottom_ref
   hexactpos 1
   vexactpos 1
   hexactsize 0
   vexactsize 1
   "text valign" center
  }
  CheckBoxWidgetClass chckbx_players {
   position 0 20
   size 0.25 20
   valign bottom_ref
   hexactpos 1
   vexactpos 1
   hexactsize 0
   vexactsize 1
   text "#lb_adm_players"
  }
  CheckBoxWidgetClass chckbx_vehicles {
   position 0.25 20
   size 0.25 20
   valign bottom_ref
   hexactpos 0
   vexactpos 1
   hexactsize 0
   vexactsize 1
   text "#lb_adm_vehicles"
  }
 }
}