FrameWidgetClass rootFrame {
 size 1 1
 halign center_ref
 valign center_ref
 hexactpos 1
 vexactpos 1
 hexactsize 0
 vexactsize 0
 scriptclass "LBMenuPopulator"
 {
  ScrollWidgetClass scroll_items {
   ignorepointer 1
   size 1 1
   hexactpos 1
   vexactpos 1
   hexactsize 0
   vexactsize 0
   scriptclass "LBGapHandler"
   "Scrollbar V" 1
   {
    WrapSpacerWidgetClass list_entries {
     ignorepointer 0
     size 1 10
     hexactpos 1
     vexactpos 1
     hexactsize 0
     vexactsize 0
     Padding 0
     Margin 1
     "Size To Content V" 1
    }
   }
   {
    ScriptParamsClass {
     gapVertical 20
    }
   }
  }
  ButtonWidgetClass btn_delete {
   size 1 20
   valign bottom_ref
   hexactpos 1
   vexactpos 1
   hexactsize 0
   vexactsize 1
   text "#lb_adm_delete_all_items"
  }
 }
 {
  ScriptParamsClass {
  }
 }
}