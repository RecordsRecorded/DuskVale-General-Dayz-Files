FrameWidgetClass rootFrame {
 position 0 0
 size 1 1
 hexactpos 1
 vexactpos 1
 hexactsize 0
 vexactsize 0
 {
  CheckBoxWidgetClass chckbx_enable {
   size 1 20
   hexactpos 1
   vexactpos 1
   hexactsize 0
   vexactsize 1
   text "#lb_adm_enable_dragging_esp_items"
  }
  CheckBoxWidgetClass chckbx_surface {
   position 0 20
   size 1 20
   hexactpos 1
   vexactpos 1
   hexactsize 0
   vexactsize 1
   text "#lb_adm_snap_object_to_surface"
  }
  CheckBoxWidgetClass chckbx_drag_camera {
   position 0 40
   size 1 20
   hexactpos 1
   vexactpos 1
   hexactsize 0
   vexactsize 1
   text "#lb_adm_enable_camera_movement_when_dragging"
  }
 }
}