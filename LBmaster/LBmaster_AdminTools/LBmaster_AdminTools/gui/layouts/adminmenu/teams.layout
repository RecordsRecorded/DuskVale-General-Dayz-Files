FrameWidgetClass rootFrame {
 size 1 1
 halign center_ref
 valign center_ref
 hexactpos 1
 vexactpos 1
 hexactsize 0
 vexactsize 0
 {
  PanelWidgetClass PanelWidget0 {
   ignorepointer 1
   position 0 0
   size 1 1
   hexactpos 1
   vexactpos 1
   hexactsize 0
   vexactsize 0
   scriptclass "LBMenuPopulator"
   {
    EditBoxWidgetClass edit_name {
     position 80 0
     size 1 20
     valign bottom_ref
     hexactpos 1
     vexactpos 1
     hexactsize 0
     vexactsize 1
     scriptclass "LBGapHandler"
     {
      ScriptParamsClass {
       gapHorizontal 80
      }
     }
    }
    TextWidgetClass txt_name {
     ignorepointer 1
     size 80 20
     valign bottom_ref
     hexactpos 1
     vexactpos 1
     hexactsize 1
     vexactsize 1
     text "#lb_name"
     "text halign" right
     "text valign" center
    }
    ButtonWidgetClass btn_new {
     position 0 100
     size 0.5 20
     valign bottom_ref
     hexactpos 1
     vexactpos 1
     hexactsize 0
     vexactsize 1
     text "#lb_adm_new_team"
    }
    ButtonWidgetClass btn_del {
     position 0 100
     size 0.5 20
     halign right_ref
     valign bottom_ref
     hexactpos 1
     vexactpos 1
     hexactsize 0
     vexactsize 1
     text "#lb_adm_del_team"
    }
    ButtonWidgetClass btn_export {
     position 0 80
     size 0.5 20
     valign bottom_ref
     hexactpos 1
     vexactpos 1
     hexactsize 0
     vexactsize 1
     text "Copy Team"
    }
    ButtonWidgetClass btn_export_all {
     position 0 80
     size 0.5 20
     halign right_ref
     valign bottom_ref
     hexactpos 1
     vexactpos 1
     hexactsize 0
     vexactsize 1
     text "Copy all Teams"
    }
    ButtonWidgetClass btn_clear_all {
     position 0 60
     size 0.5 20
     halign right_ref
     valign bottom_ref
     hexactpos 1
     vexactpos 1
     hexactsize 0
     vexactsize 1
     text "#lb_adm_team_clear_members"
    }
    ButtonWidgetClass btn_clear_offline {
     position 0 60
     size 0.5 20
     valign bottom_ref
     hexactpos 1
     vexactpos 1
     hexactsize 0
     vexactsize 1
     text "#lb_adm_team_clear_offline"
    }
    CheckBoxWidgetClass chckbx_unique {
     position 0 40
     size 0.5 20
     valign bottom_ref
     hexactpos 1
     vexactpos 1
     hexactsize 0
     vexactsize 1
     text "#lb_adm_team_unique_players"
    }
    CheckBoxWidgetClass chckbx_sync {
     position 0 40
     size 0.5 20
     halign right_ref
     valign bottom_ref
     hexactpos 1
     vexactpos 1
     hexactsize 0
     vexactsize 1
     text "Sync"
    }
    CheckBoxWidgetClass chckbx_color {
     position 0 20
     size 0.5 20
     valign bottom_ref
     hexactpos 1
     vexactpos 1
     hexactsize 0
     vexactsize 1
     text "#lb_adm_team_overwrite_esp"
    }
    ButtonWidgetClass btn_esp_color {
     position 0 20
     size 0.5 20
     halign right_ref
     valign bottom_ref
     hexactpos 1
     vexactpos 1
     hexactsize 0
     vexactsize 1
     text "#lb_adm_team_esp_color"
     {
      PanelWidgetClass panel_esp_color {
       ignorepointer 1
       size 1 1
       halign center_ref
       valign center_ref
       hexactpos 1
       vexactpos 1
       hexactsize 0
       vexactsize 0
       style LB_Clean_outline
      }
     }
    }
    TextListboxWidgetClass list_teams {
     size 1 1
     hexactpos 1
     vexactpos 1
     hexactsize 0
     vexactsize 0
     scriptclass "LBGapHandler"
     font "gui/fonts/Metron22"
     {
      ScriptParamsClass {
       gapVertical 120
      }
     }
    }
   }
   {
    ScriptParamsClass {
    }
   }
  }
 }
}