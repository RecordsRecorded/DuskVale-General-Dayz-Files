FrameWidgetClass rootFrame {
 size 1 20
 hexactpos 1
 vexactpos 1
 hexactsize 0
 vexactsize 1
 {
  SliderWidgetClass slider {
   ignorepointer 0
   size 1 20
   halign center_ref
   hexactpos 1
   vexactpos 1
   hexactsize 0
   vexactsize 1
   scriptclass "LBGapHandler"
   style Default
   maximum 10000
   vertical 0
   "fill in" 1
   {
    TextWidgetClass slider_txt {
     ignorepointer 1
     size 100 20
     halign center_ref
     valign center_ref
     hexactpos 1
     vexactpos 1
     hexactsize 1
     vexactsize 1
     text "#lb_adm_100"
     font "gui/fonts/sdf_MetronBook72"
     "outline size" 3
     "outline color" 0 0 0 1
     "exact text" 1
     "exact text size" 14
     "text halign" center
     "text valign" center
    }
   }
   {
    ScriptParamsClass {
     gapHorizontal 200
    }
   }
  }
  TextWidgetClass name {
   ignorepointer 1
   position 0 0
   size 100 20
   hexactpos 1
   vexactpos 1
   hexactsize 1
   vexactsize 1
   text "#lb_adm_health"
   "text halign" right
  }
  ButtonWidgetClass btn_apply {
   visible 0
   size 100 20
   halign right_ref
   hexactpos 1
   vexactpos 1
   hexactsize 1
   vexactsize 1
   text "#apply"
   {
    PanelWidgetClass PanelWidget0 {
     ignorepointer 1
     size 1 1
     halign center_ref
     valign center_ref
     hexactpos 1
     vexactpos 1
     hexactsize 0
     vexactsize 0
     style LB_Clean_outline
    }
   }
  }
 }
}