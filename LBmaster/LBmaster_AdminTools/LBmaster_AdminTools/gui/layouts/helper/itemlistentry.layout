PanelWidgetClass rootFrame {
 size 1 20
 hexactpos 1
 vexactpos 1
 hexactsize 0
 vexactsize 1
 scriptclass ""
 {
  PanelWidgetClass background {
   ignorepointer 1
   size 1 1
   halign right_ref
   hexactpos 1
   vexactpos 1
   hexactsize 0
   vexactsize 0
   scriptclass "LBGapHandler"
   {
    TextWidgetClass name {
     ignorepointer 1
     position 2 0
     size 1 1
     hexactpos 1
     vexactpos 1
     hexactsize 0
     vexactsize 0
    }
   }
   {
    ScriptParamsClass {
     gapHorizontal 42
    }
   }
  }
  ButtonWidgetClass btn_remove {
   size 20 20
   hexactpos 1
   vexactpos 1
   hexactsize 1
   vexactsize 1
   {
    PanelWidgetClass PanelWidget2 {
     ignorepointer 1
     size 1 1
     halign center_ref
     valign center_ref
     hexactpos 1
     vexactpos 1
     hexactsize 0
     vexactsize 0
     style LB_Clean_outline
    }
    ImageWidgetClass ImageWidget0 {
     ignorepointer 1
     size 1 1
     hexactpos 1
     vexactpos 1
     hexactsize 0
     vexactsize 0
     image0 "set:dayz_gui image:icon_x"
     mode blend
     "src alpha" 1
     "stretch mode" stretch_w_h
    }
   }
  }
  ButtonWidgetClass btn_delete {
   position 21 0
   size 20 20
   hexactpos 1
   vexactpos 1
   hexactsize 1
   vexactsize 1
   {
    PanelWidgetClass PanelWidget1 {
     ignorepointer 1
     size 1 1
     halign center_ref
     valign center_ref
     hexactpos 1
     vexactpos 1
     hexactsize 0
     vexactsize 0
     style LB_Clean_outline
    }
    ImageWidgetClass ImageWidget1 {
     ignorepointer 1
     size 0.8 0.8
     halign center_ref
     valign center_ref
     hexactpos 1
     vexactpos 1
     hexactsize 0
     vexactsize 0
     image0 "LBmaster_AdminTools/gui/icons/trashcan.paa"
     mode blend
     "src alpha" 1
     "stretch mode" stretch_w_h
    }
   }
  }
 }
}