PanelWidgetClass rootFrame {
 size 800 700
 halign center_ref
 valign center_ref
 hexactpos 1
 vexactpos 1
 hexactsize 1
 vexactsize 1
 scriptclass "LBMenuPopulator"
 style blank
 {
  PanelWidgetClass panel_received {
   visible 1
   ignorepointer 1
   size 1 1
   halign center_ref
   valign center_ref
   hexactpos 1
   vexactpos 1
   hexactsize 0
   vexactsize 0
   scriptclass "LBMenuPopulator"
   {
    XComboBoxWidgetClass combo_webhooks {
     size 1 20
     hexactpos 1
     vexactpos 1
     hexactsize 0
     vexactsize 1
    }
    ButtonWidgetClass btn_add {
     position 0 20
     size 0.4 20
     hexactpos 1
     vexactpos 1
     hexactsize 0
     vexactsize 1
     text "New Webhook"
    }
    ButtonWidgetClass btn_del {
     position 0 20
     size 0.4 20
     halign right_ref
     hexactpos 1
     vexactpos 1
     hexactsize 0
     vexactsize 1
     text "Delete Webhook"
    }
    CheckBoxWidgetClass chckbx_enabled {
     position 0 80
     size 0.3 20
     hexactpos 1
     vexactpos 1
     hexactsize 0
     vexactsize 1
     text "Enabled"
    }
    TextWidgetClass TextWidget0 {
     ignorepointer 1
     position 0 40
     size 0.2 20
     hexactpos 1
     vexactpos 1
     hexactsize 0
     vexactsize 1
     text "Name: "
     "text halign" right
    }
    EditBoxWidgetClass edit_name {
     position 0 40
     size 0.8 20
     halign right_ref
     hexactpos 1
     vexactpos 1
     hexactsize 0
     vexactsize 1
    }
    TextWidgetClass TextWidget1 {
     ignorepointer 1
