    EditBoxWidgetClass edit_url {
     position 0 60
     size 0.8 20
     halign right_ref
     hexactpos 1
     vexactpos 1
     hexactsize 0
     vexactsize 1
    }
    TextWidgetClass TextWidget2 {
     ignorepointer 1
     position 0 100
     size 0.4 20
     hexactpos 1
     vexactpos 1
     hexactsize 0
     vexactsize 1
     text " Enabled Messages"
    }
    TextListboxWidgetClass list_enabled {
     position 0 120
     size 0.45 280
     hexactpos 1
     vexactpos 1
     hexactsize 0
     vexactsize 1
     lines 14
    }
    TextListboxWidgetClass list_available {
     position 0 120
     size 0.45 280
     halign right_ref
     hexactpos 1
     vexactpos 1
     hexactsize 0
     vexactsize 1
     lines 14
    }
    ButtonWidgetClass btn_add_message {
     position 0 230
