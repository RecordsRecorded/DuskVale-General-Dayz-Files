    ButtonWidgetClass btn_del_message {
     position 0 250
     size 0.1 20
     halign center_ref
     hexactpos 1
     vexactpos 1
     hexactsize 0
     vexactsize 1
     text "->"
    }
    ButtonWidgetClass btn_add_all {
     position 0 210
     size 0.1 20
     halign center_ref
     hexactpos 1
     vexactpos 1
     hexactsize 0
     vexactsize 1
     text "<<<<"
    }
    ButtonWidgetClass btn_del_all {
     position 0 270
     size 0.1 20
     halign center_ref
     hexactpos 1
     vexactpos 1
     hexactsize 0
     vexactsize 1
     text ">>>>"
