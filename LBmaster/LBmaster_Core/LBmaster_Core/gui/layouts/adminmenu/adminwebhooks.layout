     vexactpos 1
     hexactsize 1
     vexactsize 1
     text " Limits to actions by these Admins  (empty list -> always sent):"
    }
    TextListboxWidgetClass list_steamids {
     position 0 420
     size 0.7 280
     hexactpos 1
     vexactpos 1
     hexactsize 0
     vexactsize 1
     "title visible" 1
